:root{
  --cream:#f8f3ea;--cream2:#eee6d9;--white:#fffdf9;--sage:#89977e;--sage-dark:#67745f;--gold:#d8c59d;--forest:#3d4737;--ink:#575247;--muted:#81796c;--line:#e7dccb;--shadow:0 24px 70px rgba(61,71,55,.12);--radius:30px;
}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--cream);color:var(--ink);font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;line-height:1.75}img{display:block;max-width:100%}a{color:inherit}.site-header{position:sticky;top:0;z-index:50;background:rgba(248,243,234,.86);backdrop-filter:blur(18px);border-bottom:1px solid rgba(231,220,203,.75)}.nav-wrap{width:min(1180px,92vw);margin:auto;display:flex;align-items:center;justify-content:space-between;padding:18px 0}.brand{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:var(--forest);text-decoration:none;letter-spacing:.02em}.nav{display:flex;gap:24px;align-items:center;font-size:14px}.nav a{text-decoration:none;font-weight:650;color:var(--forest)}.nav a:hover{color:var(--sage-dark)}.nav .apply{background:var(--forest);color:#fff;padding:10px 18px;border-radius:999px}.menu-toggle{display:none;background:transparent;border:1px solid var(--line);border-radius:999px;padding:8px 14px;color:var(--forest)}
.container{width:min(1120px,90vw);margin:auto}.narrow{width:min(780px,90vw);margin:auto}.center{text-align:center}.section{padding:92px 0}.soft{background:#f1e9dc}.eyebrow{text-transform:uppercase;letter-spacing:.22em;font-size:12px;font-weight:800;color:var(--sage-dark);margin:0 0 14px}h1,h2,h3{font-family:'Cormorant Garamond',serif;color:var(--forest);font-weight:700;line-height:1}h1{font-size:clamp(72px,10vw,142px);margin:0}h2{font-size:clamp(42px,6vw,74px);margin:0 0 22px}h3{font-size:31px;margin:0 0 12px}p{margin:0 0 18px}.lead{font-size:20px;color:var(--forest)}
.hero{min-height:82vh;display:grid;place-items:center;padding:120px 0 80px;background:radial-gradient(circle at top left,#fff8ed 0,#f7f0e5 40%,#e8e0d4 100%)}.hero-card{width:min(980px,90vw);background:rgba(255,253,249,.78);border:1px solid rgba(255,255,255,.75);border-radius:42px;box-shadow:var(--shadow);padding:80px 8vw;text-align:center}.hero-actions,.actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:28px}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:13px 24px;border-radius:999px;text-decoration:none;font-weight:750;border:1px solid transparent;transition:.18s ease}.btn-primary{background:var(--sage);color:white}.btn-primary:hover{background:var(--sage-dark);transform:translateY(-2px)}.btn-outline{background:rgba(255,255,255,.55);border-color:var(--line);color:var(--forest)}.btn-dark{background:var(--forest);color:#fff}.text-link{font-weight:800;color:var(--forest);text-decoration:none;border-bottom:2px solid var(--gold);padding-bottom:3px}.photo-row{display:grid;grid-template-columns:1.15fr .85fr;gap:22px;margin-top:54px}.photo-row img{width:100%;height:360px;object-fit:cover;border-radius:var(--radius);box-shadow:var(--shadow)}.photo-row .stack{display:grid;gap:22px}.photo-row .stack img{height:169px}.cards{display:grid;gap:22px}.cards.five{grid-template-columns:repeat(5,1fr)}.cards.three{grid-template-columns:repeat(3,1fr)}.card{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:30px 24px;box-shadow:0 10px 34px rgba(61,71,55,.06)}.card:before{content:"";display:block;width:42px;height:2px;background:var(--gold);margin-bottom:22px}.split{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}.image-card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:14px;box-shadow:var(--shadow)}.image-card img{border-radius:22px;width:100%;aspect-ratio:4/3;object-fit:cover}.banner{background:linear-gradient(135deg,#efe5d5,#fbf7ef);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}.testimonial{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:42px;box-shadow:var(--shadow);text-align:center}.testimonial p{font-family:'Cormorant Garamond',serif;font-size:34px;line-height:1.18;color:var(--forest)}details{background:#fff;border:1px solid var(--line);border-radius:18px;padding:20px 22px;margin-bottom:14px}summary{cursor:pointer;font-weight:800;color:var(--forest)}details p{margin-top:12px}.footer{background:#2f392d;color:#fff7ea;padding:38px 0}.footer-inner{display:flex;justify-content:space-between;gap:18px;align-items:center}.footer a{margin-left:18px;text-decoration:none;color:#fff7ea}.page-hero{padding:120px 0 56px;background:linear-gradient(135deg,#f8f3ea,#efe5d5)}.page-hero h1{font-size:clamp(58px,8vw,112px)}.simple-list{display:grid;gap:16px}.simple-item{background:#fff;border:1px solid var(--line);border-radius:22px;padding:24px}.form-grid{display:grid;gap:18px}label{display:grid;gap:8px;font-weight:700;color:var(--forest)}input,textarea,select{width:100%;border:1px solid var(--line);border-radius:16px;padding:14px 16px;background:#fff;font:inherit}textarea{min-height:140px}.notice{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:30px;box-shadow:var(--shadow)}
@media(max-width:900px){.menu-toggle{display:block}.nav{display:none;position:absolute;top:72px;left:4vw;right:4vw;background:#fff;border:1px solid var(--line);border-radius:22px;padding:18px;box-shadow:var(--shadow);flex-direction:column;align-items:stretch}.nav.open{display:flex}.hero{min-height:auto;padding-top:110px}.hero-card{padding:58px 28px}h1{font-size:64px}.section{padding:68px 0}.split,.photo-row{grid-template-columns:1fr}.cards.five,.cards.three{grid-template-columns:1fr}.photo-row img,.photo-row .stack img{height:auto;aspect-ratio:4/3}.footer-inner{flex-direction:column}.footer a{margin:0 8px}.lead{font-size:18px}}
