:root{
  --cream:#fbf7ef;
  --cream-2:#f4eee3;
  --white:#fffdf8;
  --sage:#87977b;
  --sage-dark:#637257;
  --gold:#d5c197;
  --forest:#2f3b2d;
  --text:#4d483f;
  --muted:#776f64;
  --line:#e7ddca;
  --shadow:0 22px 65px rgba(54,48,38,.13);
  --radius:28px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;background:var(--cream);color:var(--text);font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;line-height:1.7}
img{max-width:100%;display:block}
a{color:inherit}
.container{width:min(1120px,90vw);margin:auto}.narrow{width:min(760px,90vw)}.center{text-align:center}
.site-header{position:sticky;top:0;z-index:20;display:flex;justify-content:space-between;align-items:center;padding:18px 5vw;background:rgba(251,247,239,.92);backdrop-filter:blur(18px);border-bottom:1px solid rgba(231,221,202,.75)}
.brand{font-family:Cormorant Garamond,serif;font-weight:700;font-size:26px;color:var(--forest);text-decoration:none;letter-spacing:.02em}.brand small{font-family:Inter,sans-serif;text-transform:uppercase;font-size:10px;letter-spacing:.22em;color:var(--sage-dark);display:block;margin-top:-8px}
.nav{display:flex;gap:22px;align-items:center;font-size:14px}.nav a{text-decoration:none;font-weight:650;color:var(--forest)}.nav-cta{background:var(--sage);color:white!important;border-radius:999px;padding:10px 17px}.menu-toggle{display:none;border:1px solid var(--line);background:#fff;border-radius:999px;padding:9px 14px;color:var(--forest)}
.hero{padding:70px 0 88px;background:linear-gradient(180deg,#fbf7ef 0%,#f4eee3 100%)}
.hero-grid{display:grid;grid-template-columns:.92fr 1.08fr;gap:58px;align-items:center}.eyebrow{text-transform:uppercase;letter-spacing:.22em;font-size:12px;font-weight:800;color:var(--sage-dark);margin:0 0 16px}.hero h1,h2,h3{font-family:Cormorant Garamond,serif;color:var(--forest);line-height:.98;margin:0} .hero h1{font-size:clamp(68px,9vw,118px);margin-bottom:24px}.hero p{font-size:18px;color:var(--muted);margin:0 0 28px;max-width:520px}.hero-actions,.actions{display:flex;gap:14px;flex-wrap:wrap}.btn{display:inline-flex;align-items:center;justify-content:center;text-decoration:none;min-height:48px;padding:12px 23px;border-radius:999px;border:1px solid transparent;font-weight:800;transition:.2s ease}.btn-primary{background:var(--sage);color:#fff}.btn-primary:hover{background:var(--sage-dark);transform:translateY(-2px)}.btn-light{background:transparent;border-color:var(--sage);color:var(--forest)}.btn-dark{background:var(--forest);color:white}.photo-collage{display:grid;grid-template-columns:1fr .72fr;gap:18px;align-items:end}.photo-collage img{width:100%;height:100%;object-fit:cover;border-radius:var(--radius);box-shadow:var(--shadow)}.photo-main{aspect-ratio:4/5}.photo-stack{display:grid;gap:18px}.photo-stack img{aspect-ratio:1/1}.photo-note{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:22px;box-shadow:0 16px 45px rgba(54,48,38,.08);font-family:Cormorant Garamond,serif;color:var(--forest);font-size:26px;line-height:1.08}.section{padding:92px 0}.soft{background:var(--cream-2)}h2{font-size:clamp(40px,5.2vw,72px);margin-bottom:20px}h3{font-size:30px;margin-bottom:12px}.lead{font-size:21px;color:var(--forest);line-height:1.55}.split{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}.rounded-img{border-radius:var(--radius);box-shadow:var(--shadow);aspect-ratio:4/3;object-fit:cover}.cards{display:grid;gap:18px}.five{grid-template-columns:repeat(5,1fr)}.three{grid-template-columns:repeat(3,1fr)}.card{background:var(--white);border:1px solid var(--line);border-radius:24px;padding:27px 23px;box-shadow:0 10px 34px rgba(54,48,38,.06)}.card:before{content:"";display:block;width:42px;height:2px;background:var(--gold);margin-bottom:18px}.card p{margin:0;color:var(--muted);font-size:15px}.section-heading{margin-bottom:38px}.banner{background:var(--forest);color:white}.banner h2,.banner p,.banner .eyebrow{color:white}.banner .btn-light{color:white;border-color:rgba(255,255,255,.55)}.text-link{font-weight:850;color:var(--forest);text-decoration:none;border-bottom:2px solid var(--gold);padding-bottom:3px}.testimonial-card{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:42px;text-align:center}.testimonial-card p{font-family:Cormorant Garamond,serif;font-size:32px;line-height:1.18;color:var(--forest)}details{background:var(--white);border:1px solid var(--line);border-radius:18px;padding:19px 22px;margin-bottom:13px}summary{cursor:pointer;color:var(--forest);font-weight:850}.footer{background:#252e23;color:#fbf7ef;padding:32px 0}.footer-inner{display:flex;align-items:center;justify-content:space-between;gap:20px}.footer a{color:#fbf7ef;text-decoration:none;margin-left:18px}.page-hero{padding:96px 0 54px}.page-hero h1{font-family:Cormorant Garamond,serif;font-size:clamp(58px,9vw,112px);line-height:.92;color:var(--forest);margin:0 0 18px}.form-box{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:34px;box-shadow:var(--shadow)}.form-box input,.form-box textarea,.form-box select{width:100%;border:1px solid var(--line);border-radius:14px;padding:14px 15px;margin:8px 0 16px;background:#fff;font:inherit}.form-box label{font-weight:800;color:var(--forest)}
@media(max-width:980px){.five{grid-template-columns:repeat(2,1fr)}.hero-grid,.split{grid-template-columns:1fr}.hero{padding-top:46px}.photo-collage{grid-template-columns:1fr 1fr}.nav{display:none;position:absolute;top:73px;left:5vw;right:5vw;background:#fff;border:1px solid var(--line);border-radius:20px;padding:17px;box-shadow:var(--shadow);flex-direction:column;align-items:stretch}.nav.open{display:flex}.menu-toggle{display:block}.nav a{padding:8px}}
@media(max-width:620px){.hero h1{font-size:64px}.section{padding:68px 0}.five,.three{grid-template-columns:1fr}.photo-collage{grid-template-columns:1fr}.photo-stack{grid-template-columns:1fr 1fr}.site-header{padding:14px 5vw}.brand{font-size:23px}.footer-inner{flex-direction:column}.footer a{margin:0 8px}.testimonial-card{padding:28px}.testimonial-card p{font-size:26px}}
