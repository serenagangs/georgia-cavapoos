
:root{--cream:#faf7f2;--soft:#fffdf9;--white:#fff;--sage:#9dab8f;--sage-dark:#68785e;--gold:#d6c49d;--forest:#384332;--text:#4c4a43;--muted:#7d7a70;--line:rgba(214,196,157,.48);--shadow:0 24px 70px rgba(56,67,50,.12)}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--cream);color:var(--text);font-family:'Nunito Sans',Arial,sans-serif;line-height:1.75}img{max-width:100%;display:block}h1,h2,h3{font-family:'Cormorant Garamond',serif;color:var(--forest);line-height:.98;margin:0 0 18px;font-weight:600}h1{font-size:clamp(4.2rem,10vw,9rem);letter-spacing:.02em}h2{font-size:clamp(2.8rem,5.5vw,5.2rem)}h3{font-size:2rem}p{font-size:1.05rem}.site-header{position:fixed;top:0;left:0;width:100%;z-index:50;display:flex;align-items:center;justify-content:space-between;padding:18px 5.5%;background:rgba(250,247,242,.82);backdrop-filter:blur(18px);border-bottom:1px solid rgba(214,196,157,.22)}.brand{font-family:'Cormorant Garamond',serif;font-size:1.75rem;font-weight:700;color:var(--forest);text-decoration:none}.nav{display:flex;gap:22px;align-items:center}.nav a{font-size:.92rem;color:var(--forest);text-decoration:none}.nav-cta,.btn.primary{background:var(--forest);color:white!important;border-radius:999px;padding:12px 24px;text-decoration:none;display:inline-block;box-shadow:0 10px 28px rgba(56,67,50,.18)}.menu-toggle{display:none;border:1px solid var(--line);background:var(--soft);border-radius:999px;padding:8px 14px;color:var(--forest)}.hero{min-height:100vh;padding:120px 6% 80px;display:grid;place-items:center;text-align:center;background:linear-gradient(rgba(56,67,50,.10),rgba(56,67,50,.18)),url('../images/hero.jpg') center/cover no-repeat}.hero-card{max-width:920px;width:min(920px,90vw);background:rgba(250,247,242,.78);border:1px solid rgba(255,255,255,.65);border-radius:42px;padding:64px 42px;box-shadow:var(--shadow);backdrop-filter:blur(8px)}.hero-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}.btn.ghost{background:rgba(255,255,255,.72);border:1px solid var(--line);color:var(--forest);border-radius:999px;padding:12px 24px;text-decoration:none;display:inline-block}.eyebrow{text-transform:uppercase;letter-spacing:.25em;font-size:.75rem;font-weight:800;color:var(--sage-dark);margin-bottom:18px}.section{padding:110px 6%}.container{max-width:1180px;margin:auto}.narrow{max-width:780px}.center{text-align:center}.lead{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,3vw,2.35rem);line-height:1.25;color:var(--forest)}.soft{background:var(--soft)}.section-heading{text-align:center;margin-bottom:48px}.cards{display:grid;gap:24px}.four{grid-template-columns:repeat(4,1fr)}.three{grid-template-columns:repeat(3,1fr)}.two{grid-template-columns:repeat(2,1fr)}.card,.dog-card,.testimonial{background:rgba(255,255,255,.78);border:1px solid var(--line);border-radius:30px;padding:32px;box-shadow:var(--shadow)}.card-mark{display:inline-flex;width:44px;height:44px;align-items:center;justify-content:center;border-radius:50%;border:1px solid var(--gold);color:var(--sage-dark);font-size:.78rem;letter-spacing:.12em;margin-bottom:20px;background:var(--soft);font-weight:800}.split-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}.photo-frame{border-radius:36px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--line);background:var(--soft)}.photo-frame img{width:100%;height:520px;object-fit:cover}.text-link{display:inline-block;margin-top:10px;color:var(--forest);font-weight:800;text-decoration:none;border-bottom:1px solid var(--gold)}.litters-band{background:linear-gradient(135deg,#f1eadf,#fffdf9);text-align:center}.faq-item{border-bottom:1px solid #e7ddca;padding:18px 0}.faq-item button{font-family:'Cormorant Garamond',serif;font-size:1.65rem;color:var(--forest);background:transparent;border:0;padding:0;width:100%;text-align:left;cursor:pointer}.faq-item p{display:none;margin:8px 0 0}.faq-item.active p{display:block}.final-cta{text-align:center;padding:110px 6%;background:var(--forest);color:white}.final-cta h2,.footer h2{color:white}.footer{background:#2f382b;color:white;padding:58px 6%;text-align:center}.footer a{color:white;text-decoration:none;margin:0 10px}.copyright{font-size:.9rem;color:rgba(255,255,255,.68)}.page-hero{padding:160px 6% 90px;text-align:center;background:linear-gradient(135deg,#f6efe4,#fffdf9)}.page-hero h1{font-size:clamp(4rem,8vw,7.5rem)}.image-placeholder{min-height:260px;border:1px dashed var(--gold);border-radius:24px;display:grid;place-items:center;color:var(--muted);background:var(--soft);margin-bottom:22px}.reveal{opacity:0;transform:translateY(20px);transition:opacity .8s ease, transform .8s ease}.reveal.visible{opacity:1;transform:none}@media(max-width:900px){.menu-toggle{display:block}.nav{display:none;position:absolute;top:74px;right:5%;background:var(--soft);border:1px solid var(--line);box-shadow:var(--shadow);border-radius:24px;padding:20px;flex-direction:column;align-items:flex-start}.nav.open{display:flex}.four,.three,.two,.split-grid{grid-template-columns:1fr}.reverse .photo-frame{order:-1}.hero-card{padding:42px 22px}.section{padding:78px 6%}h1{font-size:clamp(3.6rem,17vw,5rem)}.photo-frame img{height:380px}}
